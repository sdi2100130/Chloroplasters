from XRPLib import XRPBoard
from XRPLib.board import XRPBoard
from machine import ADC, Pin
import time

xrp = XRPBoard()
ph_sensor = ADC(Pin(26)) 

V_REF = 3.3          # XRP operating voltage
ADC_MAX = 65535      # 16-bit ADC resolution
PH_OFFSET = 0.0      # Calibration: Adjust after testing in pH 7.0 buffer

PUMP_SPEED = 0.5     # 50% motor power
DOSE_DURATION = 2.0  # Seconds to run the pump
MIXING_TIME = 60     # Seconds to wait for chemicals to disperse


def get_calibrated_ph():
    """Reads the SEN0161 and returns a stabilized pH value."""
    totalraw = 0
    samples = 20 # High sample rate to filter motor/electrical noise
    for  in range(samples):
        total_raw += ph_sensor.read_u16()
        time.sleep(0.01)

    avg_raw = total_raw / samples
    voltage = (avg_raw / ADC_MAX) * V_REF

DFRobot standard formula: pH = 3.5 * voltage + offset
    ph_value = (3.5 * voltage) + PH_OFFSET
    return round(ph_value, 2)
def run_pump(motor_number, duration):
    """Safely triggers a pump on the XRP motor ports."""
    xrp.set_motor(motor_number, PUMP_SPEED)
    time.sleep(duration)
    xrp.set_motor(motor_number, 0)


def ph_homeostasis():
    current_ph = get_calibrated_ph()
    print(f"Current System pH: {current_ph}")

    if current_ph > 6.5:
        print(">>> pH High: Dosing Citric Acid (Pump 1)")
        run_pump(1, DOSE_DURATION)
        print(f">>> Dose complete. Waiting {MIXING_TIME}s for mixing...")
        time.sleep(MIXING_TIME)

    elif current_ph < 5.5:
        print(">>> pH Low: Dosing Potassium Bicarbonate (Pump 2)")
        run_pump(2, DOSE_DURATION)
        print(f">>> Dose complete. Waiting {MIXING_TIME}s for mixing...")
        time.sleep(MIXING_TIME)

    else:
        print(">>> pH within range (5.5 - 6.5). Monitoring...")

print("System Online: Starting pH Homeostasis...")

while True:
    try:
        ph_homeostasis()
        time.sleep(10) # Short pause between monitoring checks
    except Exception as e:
        # Emergency stop if something goes wrong with the script
        xrp.set_motor(1, 0)
        xrp.set_motor(2, 0)
        break